FROM ghcr.io/astral-sh/uv:python3.13-bookworm-slim

WORKDIR /app
ENV UV_CACHE_DIR=/tmp/uv-cache

COPY pyproject.toml uv.lock requirements-agentcore.txt ./
RUN uv sync --frozen --no-dev \
    && uv pip install --python .venv/bin/python -r requirements-agentcore.txt

COPY app ./app

EXPOSE 8080
USER 10001:10001
CMD ["/app/.venv/bin/uvicorn", "app.agentcore_runtime:app", "--host", "0.0.0.0", "--port", "8080"]
