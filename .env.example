# StockBrief-be local development environment template.
# Do not put real API keys, tokens, passwords, or production secrets in this file.

# Runtime
APP_ENV=local
LOG_LEVEL=info

# Backend
SERVICE_NAME=stockbrief-api
SERVICE_VERSION=0.1.0
API_HOST=127.0.0.1
API_PORT=8000
API_BASE_PATH=/v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Chat explanation provider. Use mock locally; set bedrock or agentcore only after IAM/model access is approved.
# BEDROCK_CHAT_MODEL_ID may be a foundation model id or an inference profile id.
# Runtime bounds: max tokens 64-1200, temperature 0.0-1.0, timeout 1-30 seconds.
CHAT_PROVIDER=mock
BEDROCK_CHAT_MODEL_ID=apac.amazon.nova-micro-v1:0
BEDROCK_CHAT_REGION=ap-northeast-2
BEDROCK_CHAT_MAX_TOKENS=700
BEDROCK_CHAT_TEMPERATURE=0.2
BEDROCK_CHAT_TIMEOUT_SECONDS=8.0
AGENTCORE_RUNTIME_URL=
AGENTCORE_RUNTIME_ARN=
AGENTCORE_RUNTIME_REGION=ap-northeast-2
AGENTCORE_RUNTIME_QUALIFIER=DEFAULT
AGENTCORE_RUNTIME_TIMEOUT_SECONDS=8.0
AGENTCORE_RUNTIME_MAX_TURNS=4
AGENTCORE_RUNTIME_USE_DEV_MODEL=false

# Database
DATABASE_URL=postgresql+psycopg://stockbrief:stockbrief@localhost:5432/stockbrief
DATABASE_SECRET_ARN=
DATABASE_HOST=
DATABASE_PORT=5432
DATABASE_NAME=stockbrief
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_TIMEOUT_SECONDS=30

# Public data providers
OPENDART_API_KEY=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Cognito auth (backend)
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
COGNITO_ISSUER=
COGNITO_JWKS_URL=

# Optional fallback or seed data provider
KRX_DATA_PATH=
